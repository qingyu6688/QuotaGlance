{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QuotaGlance",
  "version": "0.1.5",
  "identifier": "io.github.maorongkang.quotaglance",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "widget",
        "title": "QuotaGlance",
        "width": 320,
        "height": 320,
        "minWidth": 136,
        "minHeight": 136,
        "maxWidth": 380,
        "maxHeight": 420,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; connect-src 'self'; font-src 'self'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Codex 额度一览",
    "longDescription": "本地优先的 Codex 额度悬浮助手，通过官方 App Server 只读展示额度窗口。",
    "copyright": "Copyright 2026 QuotaGlance contributors",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
